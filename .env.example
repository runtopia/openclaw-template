# =============================================================================
# OpenClaw Railway Template — 环境变量说明
# =============================================================================
# 复制本文件为 .env 用于本地开发
# Railway 部署时在 Variables 面板设置
# =============================================================================

# -----------------------------------------------------------------------------
# API Key（至少填一个，触发自动配置）
# -----------------------------------------------------------------------------

# ClawRouters（推荐，支持多模型路由 + 图像/视频生成）
CLAWROUTERS_API_KEY=

# 或者直接用各家原生 Key
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# 渠道配置（按需填写）
# -----------------------------------------------------------------------------

# Telegram
# TELEGRAM_BOT_TOKEN=

# Discord
# DISCORD_BOT_TOKEN=

# Slack（需要同时填两个）
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# 飞书
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# WhatsApp（填 1 启用，启动后扫码登录）
# WHATSAPP_ENABLED=1

# 微信（填 1 启用，启动后扫码登录）
# WECHAT_ENABLED=1

# -----------------------------------------------------------------------------
# OneClaw 平台集成（心跳上报、人格同步、定时提醒）
# -----------------------------------------------------------------------------

# ONECLAW_INSTANCE_ID=
# ONECLAW_INSTANCE_SECRET=
# ONECLAW_TEMPLATE_ID=
# ONECLAW_API_URL=https://www.oneclaw.net/api

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------

# Railway 自动注入，本地默认 8080
PORT=8080

# sidecar 监听的端口（即 PORT），openclaw gateway 内部端口
INTERNAL_GATEWAY_PORT=18789

# Gateway token（不填则自动生成并持久化到 STATE_DIR/gateway.token）
# OPENCLAW_GATEWAY_TOKEN=

# State 目录（Railway 挂 Volume 到 /data，本地可用任意路径）
OPENCLAW_STATE_DIR=/tmp/openclaw-dev
OPENCLAW_WORKSPACE_DIR=/tmp/openclaw-dev/workspace

# openclaw CLI 入口（本地开发必须填，指向本机安装路径）
# 查找：node -e "require.resolve('openclaw')" 或 which openclaw
OPENCLAW_ENTRY=/Users/luopeng/.nvm/versions/node/v22.22.0/lib/node_modules/openclaw/dist/entry.js

# 默认模型（不填则由 provider 决定）
# DEFAULT_MODEL=clawrouters/auto
