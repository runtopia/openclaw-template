{
  "name": "openclaw-railway-template",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "node --env-file-if-exists=.env src/sidecar.js",
    "dev:server": "node --env-file-if-exists=.env src/server.js",
    "start": "node src/sidecar.js",
    "lint": "node -c src/sidecar.js && node -c src/server.js",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^5.1.0",
    "http-proxy": "^1.18.1",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ],
    "patchedDependencies": {
      "http-proxy@1.18.1": "patches/http-proxy@1.18.1.patch"
    }
  }
}
